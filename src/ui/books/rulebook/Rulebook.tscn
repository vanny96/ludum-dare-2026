[node name="DecodeText" type="RichTextLabel" parent="Pages/Page3/PageLeft/VBoxContainer/MarginContainer" unique_id=918462879]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/normal_font_size = 26
bbcode_enabled = true
text = "Not all text is what it seems. If the text seems garbled to you, it might be encrypted. These are some cyphers and how to decode them.

[font_size=30]Ceasar[/font_size]
A caesar cypher modifies text by [wave]shifting[/wave] along an alphabet. For example if A is shifted by 2, it becomes C (a->b->c). To undo this, find a shift that makes the text ungarbled, since any caesar cipher can be undone by just shifting back.

[font_size=30]Atbash[/font_size]
Atbash works similarly, but by [wave]mirroring[/wave] the alphabet instead! A becomes Z, Z becomes A. Use the handy decoder tool to find the correct letters.
"
fit_content = true
autowrap_mode = 2

