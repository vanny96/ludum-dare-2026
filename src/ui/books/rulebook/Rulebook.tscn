theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "Spies are not always your ally. These are some tips to distinguish the enemy messages from our very own liars!
[ul]Trust your instinct! Sometimes the message is just the truth.
Location, location, location! Check whether they are able to be where they claim they are.
Does the encryption seem to fail? Maybe the encryption is not the problem.
Spies may contact  you with a codeword. Be sure to check whether this codeword is actually correct."
fit_content = true
autowrap_mode = 2

