theme_override_font_sizes/normal_font_size = 26
bbcode_enabled = true
text = "If you read this, you are chosen to be the next junior spymaster. Take heed of the task at hand:
[ul] Decode the incoming message using our modern decoding system, found on page 2.
Determine if the message is from an adversarial spy or not. You can find a list of tips on page 3.
Document the information where needed.
Send your determination to the senior spymaster.
[/ul]

Make sure to do your task diligently. You will be docked pay for every mistake. You need our money more than we need you, so do your task quickly, cheaply and good at the same time.
"
fit_content = true
autowrap_mode = 2

